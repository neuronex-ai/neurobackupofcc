# ============================================
# NeuroNex OS - Lean MVP Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# ─── Supabase (Database, Auth, Storage) ──────────────────────
# Required for core functionality
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key is only used for server-side operations (Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Synapse LLM / Voice ─────────────────────────────────────
# Server-side secrets only. Configure these in Supabase Edge Function Secrets.
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_VOICE_RENDER_MODEL=llama-3.1-8b-instant
DEEPGRAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=brazilsouth
# Optional: the renderer automatically tries compatible pt-BR voices if omitted.
AZURE_SPEECH_VOICE=pt-BR-ThalitaMultilingualNeural

# Optional additional model providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ─── Voice AI (ElevenLabs) ──────────────────────────────────
# Optional legacy integration
VITE_ELEVENLABS_AGENT_ID=

# ─── Financial Providers (Asaas BaaS v3) ─────────────────────
# Note: Stripe is NOT used in this project.
ASAAS_API_KEY=
ASAAS_API_URL=https://www.asaas.com/api/v3

# ─── Automation & Workflows (N8N) ───────────────────────────
N8N_API_KEY=
N8N_WEBHOOK_URL=

# ─── Monitoring & CI/CD ─────────────────────────────────────
SENTRY_DSN=
GITHUB_TOKEN=

# ─── Core Configuration ─────────────────────────────────────
NODE_ENV=development
VITE_APP_VERSION=2.1.0-lean-mvp
