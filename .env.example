# ============================================
# NeuroNex OS - Lean MVP Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# ─── Supabase (Database, Auth, Storage) ──────────────────────
# Required for core functionality
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key is only used for server-side operations (Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM Providers ───────────────────────────────────────────
# Required for Synapse AI and Voice Mode
VITE_GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ─── Voice AI (ElevenLabs) ──────────────────────────────────
# Optional: Get your Agent ID from the ElevenLabs Dashboard
VITE_ELEVENLABS_AGENT_ID="agent_4001kk3hxgv7f50vqeq4x965sr9z"

# ─── Financial Providers (Asaas BaaS v3) ─────────────────────
# Note: Stripe is NOT used in this project.
ASAAS_API_KEY=
ASAAS_API_URL=https://www.asaas.com/api/v3

# ─── Automation & Workflows (N8N) ───────────────────────────
N8N_API_KEY=
N8N_WEBHOOK_URL=

# ─── Monitoring & CI/CD ─────────────────────────────────────
SENTRY_DSN=
GITHUB_TOKEN=

# ─── Core Configuration ─────────────────────────────────────
NODE_ENV=development
VITE_APP_VERSION=2.1.0-lean-mvp
