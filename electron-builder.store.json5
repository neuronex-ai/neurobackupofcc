{
  // Microsoft Store / MSIX-AppX build.
  // Keep this separate from electron-builder.json5 so the NSIS desktop build
  // remains unchanged while the Store submission identity is being validated.
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "extends": "./electron-builder.json5",

  "appId": "com.neuronex.desktop",
  "productName": "NeuroNex AI",

  "win": {
    "target": [
      {
        "target": "appx",
        "arch": ["x64"]
      }
    ],
    "icon": "public/favicon-256px.png",
    "artifactName": "NeuroNex-AI-Store-${version}.${ext}"
  },

  "appx": {
    // Replace these two values with the exact identity from Microsoft Partner Center.
    "identityName": "NEURONEXAI.NeuroNexAI",
    "publisher": "CN=REPLACE_WITH_MICROSOFT_PARTNER_CENTER_PUBLISHER",

    "publisherDisplayName": "NeuroNex AI",
    "applicationId": "NeuroNexAI",
    "displayName": "NeuroNex AI",
    "backgroundColor": "#09090B",
    "languages": ["pt-BR"],
    "showNameOnTiles": true
  },

  // Store packages are signed and updated by Microsoft Store after submission.
  "publish": null
}
